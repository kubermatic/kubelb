+          image: "{{ include "agentgateway.imageRegistry" (dict "registry" (.Values.controller.image.registry | default .Values.image.registry) "global" .Values.global.imageRegistry) }}/{{ .Values.controller.image.repository }}:{{ include "agentgateway.imageTag" (.Values.controller.image.tag | default .Values.image.tag | default .Chart.AppVersion) }}"
           imagePullPolicy: {{ .Values.controller.image.pullPolicy | default .Values.image.pullPolicy }}
