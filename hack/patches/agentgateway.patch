diff -ruN --exclude=README.md --exclude=README.md.gotmpl a/agentgateway/templates/_helpers.tpl b/agentgateway/templates/_helpers.tpl
--- a/agentgateway/templates/_helpers.tpl	2026-07-22 14:19:21
+++ b/agentgateway/templates/_helpers.tpl	2026-07-22 14:19:21
@@ -95,3 +95,30 @@
 {{- end -}}
 {{- end }}
 
+{{/*
+Resolve a mirrored image registry value. Takes a dict with:
+  registry: source registry (e.g. .Values.controller.image.registry | default .Values.image.registry)
+  global:   value of .Values.global.imageRegistry (may be empty)
+When global is set and registry's first segment looks like a host (contains
+"." or ":"), strips that segment and prepends global. Otherwise returns
+registry unchanged. Used to thread global.imageRegistry through air-gapped
+deployments for both controller and proxy images.
+*/}}
+{{- define "agentgateway.imageRegistry" -}}
+{{- $registry := .registry -}}
+{{- if .global -}}
+  {{- $parts := splitList "/" $registry -}}
+  {{- $path := $registry -}}
+  {{- if or (contains "." (index $parts 0)) (contains ":" (index $parts 0)) -}}
+    {{- $path = join "/" (slice $parts 1) -}}
+  {{- end -}}
+  {{- if $path -}}
+    {{- printf "%s/%s" (trimSuffix "/" .global) $path -}}
+  {{- else -}}
+    {{- trimSuffix "/" .global -}}
+  {{- end -}}
+{{- else -}}
+  {{- $registry -}}
+{{- end -}}
+{{- end }}
+
